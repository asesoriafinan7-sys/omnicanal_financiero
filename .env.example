# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Ecosistema Omnicanal Financiero v3.0
# Copiar a .env y completar con valores reales antes de ejecutar.
# NUNCA subir .env al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080

# ── Google Cloud Platform ─────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=mi-proyecto-gcp-id
GOOGLE_APPLICATION_CREDENTIALS=infra/service_account.json
VERTEX_AI_LOCATION=us-central1
FIRESTORE_COLLECTION=wicapital_creditos

# ── Vertex AI — Modelos ───────────────────────────────────────────────────────
# Endpoint IDs del Model Garden (Vertex AI MaaS)
LLAMA_ENDPOINT_ID=meta/llama-3.3-70b-instruct-maas
MISTRAL_ENDPOINT_ID=mistral-ai/mistral-large@latest

# ── Google Sheets CRM ─────────────────────────────────────────────────────────
GSHEETS_SPREADSHEET_ID=1ABC...XYZ         # ID del Google Sheet (de la URL)
GSHEETS_CREDENTIALS_JSON=infra/service_account.json   # Ruta o JSON raw
GSHEETS_PROSPECTOS_TAB=Prospectos
GSHEETS_CAMPANAS_TAB=Campañas
GSHEETS_WICAPITAL_TAB=WiCapital

# ── Meta — WhatsApp Cloud API ─────────────────────────────────────────────────
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=123456789012345
META_VERIFY_TOKEN=mi_token_secreto_webhook_2025     # Token libre — ponlo también en Meta Business Manager
META_API_VERSION=v20.0

# ── Meta — Página Facebook / Instagram ────────────────────────────────────────
# Necesario para publicaciones orgánicas
META_PAGE_ID=123456789                         # ID de tu Página de Facebook
META_IG_USER_ID=987654321                      # ID de Usuario IG vinculado a la página

# ── TikTok Ads / Content API ──────────────────────────────────────────────────
# Obtener en: developers.tiktok.com → "Login Kit" + "Content Posting API"
TIKTOK_ACCESS_TOKEN=                           # Dejar vacío hasta obtener credenciales
TIKTOK_OPEN_ID=                                # Dejar vacío hasta obtener credenciales

# ── LinkedIn Marketing API ────────────────────────────────────────────────────
# Obtener en: linkedin.com/developers → Crear app → Permisos: w_member_social
LINKEDIN_ACCESS_TOKEN=                         # Dejar vacío hasta obtener credenciales
LINKEDIN_ORGANIZATION_ID=                      # ID de la página organización (usar si tienes Página empresa)
LINKEDIN_PERSON_ID=                            # ID personal (si publicas en perfil personal)

# ── Email SMTP (Gmail) ────────────────────────────────────────────────────────
# IMPORTANTE: SMTP_PASS debe ser una "Contraseña de Aplicación" de Google,
# NO tu contraseña habitual de Gmail.
# Crear en: myaccount.google.com → Seguridad → Búsqueda "Contraseñas de aplicación"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                                  # 465=SSL, 587=STARTTLS
SMTP_USER=asesoriafinan7@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx                  # Contraseña de Aplicación de 16 caracteres

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100123456789                  # ID del grupo o chat individual (negativo para grupos)

# ── WiCapital CRM Scraper ─────────────────────────────────────────────────────
WICAPITAL_LOGIN_URL=https://wicapital.co/crm/login   # URL exacta de login
WICAPITAL_USER=mi_usuario_crm
WICAPITAL_PASS=mi_contraseña_crm

# ── Meta Ads (opcional — para futuras campañas pagas) ─────────────────────────
META_ADS_ACCOUNT_ID=                           # ID sin "act_" (ej: 1234567890)
META_ADS_ACCESS_TOKEN=                         # Token de Meta Ads Manager

# ── HubSpot (Fase 2 — Vivienda Total API) ─────────────────────────────────────
HUBSPOT_PRIVATE_APP_TOKEN=                     # Dejar vacío — Fase 2
