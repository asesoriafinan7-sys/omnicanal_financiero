# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Ecosistema Omnicanal Financiero
# ─────────────────────────────────────────────────────────────────────────────

# Secretos y credenciales — NUNCA subir al repositorio
.env
*.json
!package.json
infra/service_account.json
infra/*.json
*service_account*
*credentials*
*secrets*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
env/
pip-wheel-metadata/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Bases de datos y archivos de datos sensibles
bases/
chats/
*.xlsx
*.csv
!requirements*.txt

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Cloud Build / Docker
.dockerignore

# OS
.DS_Store
Thumbs.db
